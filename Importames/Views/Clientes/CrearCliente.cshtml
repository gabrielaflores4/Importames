@model Importames.Models.ClienteModel
@{
    Layout = null;
}
<form id="formCliente" class="form-grid" autocomplete="off">
    <h2 class="form-title">Registrar Nuevo Cliente</h2>
    <div id="mensaje-modal" class="mensaje-form"></div>

    <div class="form-group">
        <label>NOMBRE</label>
        <input type="text" name="Nombre" required />
    </div>

    <div class="form-group">
        <label>APELLIDO</label>
        <input type="text" name="Apellido" required />
    </div>

    <div class="form-group full">
        <label>DUI</label>
        <input type="text" name="Dui" maxlength="10" required placeholder="00000000-0" />
    </div>

    <div class="form-group">
        <label>TELÉFONO</label>
        <input type="text" name="Telefono" maxlength="8" required />
    </div>

    <div class="form-group">
        <label>CORREO ELECTRÓNICO</label>
        <input type="email" name="Correo" required />
    </div>

    <div class="form-group full">
        <label>DIRECCIÓN</label>
        <input type="text" name="Direccion" required />
    </div>

    <div class="modal-actions full">
        <button type="button" class="btn btn-cancel" onclick="cerrarModal()">Cancelar</button>
        <button type="button" class="btn btn-save" onclick="guardarCliente()">Guardar</button>
    </div>
</form>