@{
    ViewData["Title"] = "Cotizaciones";
}

@section Styles {
    <link rel="stylesheet" href="~/css/cotizaciones.css" />
}

<div class="cotizacion-container">

    <div>

        <div class="panel-vehiculo">

            <div class="titulo">
                Datos vehiculo
            </div>

            <table class="tabla-costos">

                <tr class="gris">
                    <td>APUESTA DEL VEHICULO</td>
                    <td>
                        <input type="text" class="textbox" id="apuestaVehiculo">
                    </td>
                </tr>

                <tr class="gris">
                    <td>PRECIO DE VEHICULO CON FEES</td>
                    <td>
                        <input type="text" class="textbox" id="precioFees">
                    </td>
                </tr>

                <tr class="gris">
                    <td>COMISION</td>
                    <td>
                        <input type="text" class="textbox" id="comision">
                    </td>
                </tr>

                <tr class="verde">
                    <td>GRUA</td>
                    <td>
                        <input type="text" class="textbox" id="grua">
                    </td>
                </tr>

                <tr class="verde">
                    <td>BL</td>
                    <td>
                        <input type="text" class="textbox" id="bl">
                    </td>
                </tr>

                <tr class="verde">
                    <td>FLETE</td>
                    <td>
                        <input type="text" class="textbox" id="flete">
                    </td>
                </tr>

                <tr class="verde">
                    <td>COMISION DE FLETE</td>
                    <td>
                        <input type="text" class="textbox" id="comisionFlete">
                    </td>
                </tr>

                <tr class="beige">
                    <td>IMPUESTO ADUANA</td>
                    <td>
                        <input type="text" class="textbox" id="impuesto">
                    </td>
                </tr>

                <tr class="beige">
                    <td>TRAMITE ADUANAL</td>
                    <td>
                        <input type="text" class="textbox" id="tramiteAduanal">
                    </td>
                </tr>

                <tr class="beige">
                    <td>GRUA DE ADUANA</td>
                    <td>
                        <input type="text" class="textbox" id="gruaAduana">
                    </td>
                </tr>

                <tr class="beige">
                    <td>TRANSFERENCIA</td>
                    <td>
                        <input type="text" class="textbox" id="transferencia">
                    </td>
                </tr>

                <tr class="beige">
                    <td>STORAGE</td>
                    <td>
                        <input type="text" class="textbox" id="storage">
                    </td>
                </tr>

                <tr class="beige">
                    <td>ENVIO DE FEDEX IAAI</td>
                    <td>
                        <input type="text" class="textbox" id="tituloFedex">
                    </td>
                </tr>

                <tr class="beige">
                    <td>VENTA</td>
                    <td>
                        <input type="text" class="textbox" id="venta">
                    </td>
                </tr>

                <tr class="beige">
                    <td>PAGO A CUENTA</td>
                    <td>
                        <input type="text" class="textbox" id="pagoCuenta">
                    </td>
                </tr>

                <tr class="beige">
                    <td>DEPOSITO DEDUCIBLE</td>
                    <td>
                        <input type="text"
                               class="textbox"
                               id="depositoDeducible"
                               value="0">
                    </td>
                </tr>

                <tr class="gris">
                    <td>REPARACION PINTOR</td>
                    <td>
                        <input type="text" class="textbox" id="reparacionPintor" value="0">
                    </td>
                </tr>

                <tr class="gris">
                    <td>REPUESTOS</td>
                    <td>
                        <input type="text" class="textbox" id="repuestos" value="0">
                    </td>
                </tr>

                <tr class="gris">
                    <td>TRAMITE DE PLACAS</td>
                    <td>
                        <input type="text" class="textbox" id="tramitePlacas" value="0">
                    </td>
                </tr>

                <tr class="gris">
                    <td>AUTORIZACION ADUANAL</td>
                    <td>
                        <input type="text" class="textbox" id="autorizacion" value="0">
                    </td>
                </tr>

                <tr class="gris">
                    <td>EMISION DE GASES</td>
                    <td>
                        <input type="text" class="textbox" id="emisionGases" value="0">
                    </td>
                </tr>

                <tr class="gris">
                    <td>EXPERTICIE</td>
                    <td>
                        <input type="text" class="textbox" id="experticie" value="0">
                    </td>
                </tr>

                <tr class="gris">
                    <td>EXPERTICIE EN SISTEMA</td>
                    <td>
                        <input type="text" class="textbox" id="experticieSistema" value="0">
                    </td>
                </tr>

            </table>

        </div>

        <div class="acciones-superiores">

            <button type="button"
                    class="btn-pdf"
                    style="width:70%;"
                    onclick="generarPDF()">

                LISTO!

            </button>

            <button type="button"
                    class="btn-buscar"
                    style="width:30%;"
                    onclick="window.open('http://almacenadoranejapa.com/#opc_calculadora', '_blank')">

                Calcular Impuesto

            </button>

        </div>

    </div>

    <div class="panel-cliente">

        <div class="titulo">
            Datos del cliente
        </div>

        <table class="tabla-cliente">

            <tr>
                <td class="label">NOMBRE CLIENTE:</td>
                <td>
                    <input type="text"
                           class="textbox"
                           id="nombreCliente">
                </td>
            </tr>

            <tr>
                <td class="label">TELEFONO:</td>
                <td>
                    <input type="text"
                           class="textbox"
                           id="telefonoCliente">
                </td>
            </tr>

            <tr>
                <td class="label">CORREO ELECTRONICO:</td>
                <td>
                    <input type="text"
                           class="textbox"
                           id="correoCliente">
                </td>
            </tr>

            <tr>
                <td class="label">MARCA DE VEHICULO:</td>
                <td>
                    <input type="text"
                           class="textbox"
                           id="marcaVehiculo">
                </td>
            </tr>

            <tr>
                <td class="label">FECHA DE SUBASTA:</td>
                <td>
                    <input type="text"
                           class="textbox"
                           id="fechaSubasta">
                </td>
            </tr>

            <tr>
                <td class="label">SUBASTA:</td>
                <td>

                    <select class="textbox" id="subasta">

                        <option>COPART</option>
                        <option>IAAI</option>

                    </select>

                </td>
            </tr>

            <tr>
                <td class="label">NUMERO DE STOCK:</td>
                <td>
                    <input type="text"
                           class="textbox"
                           id="numeroStock">
                </td>
            </tr>

            <tr>
                <td class="label">LUGAR O ESTADO:</td>
                <td>
                    <input type="text"
                           class="textbox"
                           id="lugarEstado">
                </td>
            </tr>

            <tr>
                <td class="label">ADUANA DESTINO:</td>
                <td>
                    <input type="text"
                           class="textbox"
                           id="aduanaDestino"
                           value="NEJAPA">
                </td>
            </tr>

            <tr>
                <td class="label">NAVIERA:</td>
                <td>

                    <select class="textbox" id="naviera">

                        <option>Polariz</option>
                        <option>Inbakar</option>
                        <option>MATUS</option>
                        <option>NorthAtlantic</option>

                    </select>

                </td>
            </tr>

        </table>

    </div>

</div>

<form id="formPDF"
      method="post"
      action="@Url.Action("GenerarPDF", "Cotizaciones")">

    <input type="hidden" name="nombreCliente" id="pdf_nombreCliente">
    <input type="hidden" name="telefonoCliente" id="pdf_telefonoCliente">
    <input type="hidden" name="correoCliente" id="pdf_correoCliente">

    <input type="hidden" name="marcaVehiculo" id="pdf_marcaVehiculo">
    <input type="hidden" name="fechaSubasta" id="pdf_fechaSubasta">
    <input type="hidden" name="subasta" id="pdf_subasta">
    <input type="hidden" name="numeroStock" id="pdf_numeroStock">
    <input type="hidden" name="lugarEstado" id="pdf_lugarEstado">
    <input type="hidden" name="aduanaDestino" id="pdf_aduanaDestino">
    <input type="hidden" name="naviera" id="pdf_naviera">

    <input type="hidden" name="apuestaVehiculo" id="pdf_apuestaVehiculo">
    <input type="hidden" name="precioFees" id="pdf_precioFees">
    <input type="hidden" name="comision" id="pdf_comision">

    <input type="hidden" name="grua" id="pdf_grua">
    <input type="hidden" name="bl" id="pdf_bl">
    <input type="hidden" name="flete" id="pdf_flete">
    <input type="hidden" name="comisionFlete" id="pdf_comisionFlete">

    <input type="hidden" name="impuesto" id="pdf_impuesto">
    <input type="hidden" name="tramiteAduanal" id="pdf_tramiteAduanal">
    <input type="hidden" name="gruaAduana" id="pdf_gruaAduana">
    <input type="hidden" name="transferencia" id="pdf_transferencia">
    <input type="hidden" name="storage" id="pdf_storage">
    <input type="hidden" name="tituloFedex" id="pdf_tituloFedex">
    <input type="hidden" name="venta" id="pdf_venta">
    <input type="hidden" name="pagoCuenta" id="pdf_pagoCuenta">

    <input type="hidden" name="reparacionPintor" id="pdf_reparacionPintor">
    <input type="hidden" name="repuestos" id="pdf_repuestos">
    <input type="hidden" name="tramitePlacas" id="pdf_tramitePlacas">
    <input type="hidden" name="autorizacion" id="pdf_autorizacion">
    <input type="hidden" name="emisionGases" id="pdf_emisionGases">
    <input type="hidden" name="experticie" id="pdf_experticie">
    <input type="hidden" name="experticieSistema" id="pdf_experticieSistema">

</form>

@section Scripts {
    <script src="~/js/cotizaciones.js"></script>
}