<div class="settings-modal" id="settingsModal">
    <div class="settings-content">

        <div class="settings-header">
            <h3>Configuraciones</h3>

            <button class="close-settings" id="closeSettings">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <div class="settings-body">

            <div class="settings-section">
                <h4>Apariencia</h4>

                <div class="settings-item">
                    <div class="settings-item-left">
                        <i class="bi bi-moon"></i>

                        <div>
                            <span>Modo oscuro</span>
                            <small>Cambiar apariencia del sistema</small>
                        </div>
                    </div>

                    <label class="switch">
                        <input type="checkbox" id="darkModeToggle">
                        <span class="slider"></span>
                    </label>
                </div>
            </div>

            <div class="settings-section">
                <h4>Sistema</h4>

                <div class="settings-item">
                    <div class="settings-item-left">
                        <i class="bi bi-info-circle"></i>

                        <div>
                            <span>Versión del sistema</span>
                            <small>Importames v1.0</small>
                        </div>
                    </div>
                </div>
            </div>

            <div class="settings-section">
                <h4>Ayuda</h4>

                <button class="settings-item faq-toggle" id="openFaq">

                    <div class="settings-item-left">
                        <i class="bi bi-question-circle"></i>

                        <div>
                            <span>Preguntas frecuentes</span>
                            <small>Centro de ayuda del sistema</small>
                        </div>
                    </div>

                </button>
            </div>

            <div class="settings-section">
                <h4>Contacto</h4>

                <a href="mailto:gabriela.flores9@catolica.edu.sv" class="settings-item">

                    <div class="settings-item-left">
                        <i class="bi bi-envelope"></i>

                        <div>
                            <span>Soporte</span>
                            <small>gabriela.flores9@catolica.edu.sv</small>
                        </div>
                    </div>

                </a>
            </div>

        </div>

    </div>
</div>