<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Importames</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tables.css">
    <link rel="stylesheet" href="~/css/buttons.css">
    <link rel="stylesheet" href="~/css/forms.css">
    <link rel="stylesheet" href="~/css/dashboard.css">
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="app-layout">
        <aside class="sidebar">
            <div class="sidebar-header">
                <img src="~/img/IMG_7649" alt="Logo" class="logo">
                <span>Importames</span>
            </div>
            <nav class="sidebar-nav">
                <div class="nav-section">
                    <div class="nav-section-title">PRINCIPAL</div>
                    <a class="nav-item" asp-area="" asp-controller="Dashboard" asp-action="Dashboard">
                        <i class="bi bi-house-door"></i> Inicio
                    </a>
                    <a class="nav-item" asp-area="" asp-controller="Vehiculos" asp-action="Index">
                        <i class="bi bi-truck"></i> Vehículos
                    </a>
                    <a class="nav-item" asp-area="" asp-controller="Cotizaciones" asp-action="Index">
                        <i class="bi bi-truck"></i> Cotizaciones
                    </a>
                </div>
                <div class="nav-section">
                    <div class="nav-section-title">GESTIÓN</div>
                    <a class="nav-item" asp-area="" asp-controller="Clientes" asp-action="Index">
                        <i class="bi bi-people"></i> Clientes
                    </a>
                    <a class="nav-item" asp-area="" asp-controller="Usuarios" asp-action="Index">
                        <i class="bi bi-person-badge"></i> Usuarios
                    </a>
                </div>
                <div class="nav-section">
                    <a class="nav-item" asp-area="" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-box-arrow-right"></i> Logout
                    </a>
                </div>
            </nav>
        </aside>

        <main class="main-content">
            <div class="topbar">

                <div class="topbar-left">
                    <h2>@ViewData["Title"]</h2>
                </div>

                <div class="topbar-right">
                    <button class="topbar-btn">
                        <i class="bi bi-gear"></i>
                    </button>

                    <button class="topbar-btn">
                        <i class="bi bi-bell"></i>
                    </button>

                    <!--Usuario de Ejemplo-->
                    <div class="topbar-user">U</div>
                </div>
            </div>

            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
    @RenderBody()
</body>
</html>