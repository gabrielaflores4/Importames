@{
    var rol = Context.Session.GetString("rol");
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Importames</title>

    <script>
        if (localStorage.getItem("darkMode") === "enabled") {
            document.documentElement.classList.add("dark-mode");
        }
    </script>

    <link rel="icon" type="image/x-icon" href="~/img/logoImportames.ico">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/tables.css">
    <link rel="stylesheet" href="~/css/buttons.css">
    <link rel="stylesheet" href="~/css/forms.css">
    <link rel="stylesheet" href="~/css/dashboard.css">
    <link rel="stylesheet" href="~/css/perfil.css">
    <link rel="stylesheet" href="~/css/settings.css">

    @await RenderSectionAsync("Styles", required: false)



</head>

<body>

    <div class="app-layout">

        <aside class="sidebar @(Context.Request.Cookies["sidebarClosed"] == "true" ? "closed" : "")">

            <div class="sidebar-header">
                <div class="sidebar-header-left">
                    <img src="~/img/LogoLayout.PNG" alt="Logo" class="logo">
                    <span>Importames</span>
                </div>

                <button class="toggle-sidebar-btn" id="toggleSidebar">
                    <i class="bi bi-list"></i>
                </button>
            </div>

            <nav class="sidebar-nav">

                <div class="nav-section">

                    <div class="nav-section-title">PRINCIPAL</div>

                    <a class="nav-item" asp-area="" asp-controller="Dashboard" asp-action="Dashboard">
                        <i class="bi bi-house-door"></i>
                        <span>Inicio</span>
                    </a>

                    <a class="nav-item" asp-area="" asp-controller="Vehiculos" asp-action="Index">
                        <i class="bi bi-truck"></i>
                        <span>Vehículos</span>
                    </a>

                    <a class="nav-item" asp-area="" asp-controller="Cotizaciones" asp-action="Index">
                        <i class="bi bi-bar-chart-line"></i>
                        <span>Reportes</span>
                    </a>

                </div>

                <div class="nav-section">

                    <div class="nav-section-title">GESTIÓN</div>

                    <a class="nav-item" asp-area="" asp-controller="Clientes" asp-action="Index">
                        <i class="bi bi-people"></i>
                        <span>Clientes</span>
                    </a>

                    @if (rol == "Administrador")
                    {
                        <a class="nav-item" asp-area="" asp-controller="Usuarios" asp-action="Index">
                            <i class="bi bi-person-badge"></i>
                            <span>Usuarios</span>
                        </a>
                    }

                </div>

                <div class="nav-section">

                    <a class="nav-item" asp-area="" asp-controller="Home" asp-action="Logout">
                        <i class="bi bi-box-arrow-right"></i>
                        <span>Logout</span>
                    </a>

                </div>

            </nav>

        </aside>

        <main class="main-content @(Context.Request.Cookies["sidebarClosed"] == "true" ? "expanded" : "")">

            <div class="topbar @(Context.Request.Cookies["sidebarClosed"] == "true" ? "expanded" : "")">

                <div class="topbar-left">
                    <h2>@ViewData["Title"]</h2>
                </div>

                <div class="topbar-right">

                    <button class="topbar-btn" id="openSettings">
                        <i class="bi bi-gear"></i>
                    </button>
                    <div class="topbar-user" id="userMenuBtn">
                        @(Context.Session.GetString("nombre_usuario")?[0].ToString().ToUpper() ?? "U")
                    </div>
                    <div class="user-dropdown" id="userDropdown">
                        <div class="user-dropdown-header">
                            <div class="user-dropdown-avatar">
                                @(Context.Session.GetString("nombre_usuario")?[0].ToString().ToUpper() ?? "U")
                            </div>
                            <div>
                                <div class="user-dropdown-name">
                                    @Context.Session.GetString("nombre_usuario")
                                </div>

                                <div class="user-dropdown-email">
                                    @Context.Session.GetString("correo")
                                </div>
                            </div>
                        </div>
                        <div class="user-dropdown-divider"></div>

                        <a class="user-dropdown-item"
                           id="abrirPerfil"
                           asp-area=""
                           asp-controller="Usuarios"
                           asp-action="Perfil">

                            <i class="bi bi-person"></i>
                            <span>Ver perfil</span>
                        </a>
                    </div>
                </div>
            </div>
            @RenderBody()
        </main>
    </div>

    <div id="modalContainer"></div>

    <partial name="SettingsModal" />
    <partial name="FaqModal" />
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/sidebar.js"></script>
    <script src="~/js/settings.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>