@model Importames.Models.UsuarioModel
@{
    Layout = null;
}

<form id="formEditarUsuario" class="form-grid" autocomplete="off">
    <h2 class="form-title">Editar Usuario</h2>

    <div id="mensaje-modal" class="mensaje-form"></div>

    <!-- ID oculto -->
    <input type="hidden" name="IdUsuario" value="@Model.IdUsuario" />

    <div class="form-group">
        <label>NOMBRE</label>
        <input type="text" name="Nombre" value="@Model.Nombre" required />
    </div>

    <div class="form-group">
        <label>APELLIDO</label>
        <input type="text" name="Apellido" value="@Model.Apellido" required />
    </div>

    <div class="form-group">
        <label>USERNAME</label>
        <input type="text" name="Username" value="@Model.Username" required />
    </div>

    <div class="form-group">
        <label>CONTRASEÑA</label>
        <input type="text" name="Password" value="@Model.Password" required />
    </div>

    <div class="form-group">
        <label>ROL</label>
        <div class="form-group">
            <select name="Rol" required>
              

                @if (Model.Rol == "Administrador")
                {
                    <option value="Administrador" selected>ADMIN</option>
                }
                else
                {
                    <option value="Administrador">ADMIN</option>
                }

                @if (Model.Rol == "Empleado")
                {
                    <option value="Empleado" selected>EMPLEADO</option>
                }
                else
                {
                    <option value="Empleado">EMPLEADO</option>
                }
            </select>
</div>
    </div>

    <div class="form-group">
        <label>TELÉFONO</label>
        <input type="text" name="Telefono" value="@Model.Telefono" maxlength="8" />
    </div>

    <div class="form-group full">
        <label>CORREO ELECTRÓNICO</label>
        <input type="email" name="Correo" value="@Model.Correo" />
    </div>

    <div class="modal-actions full">
        <button type="button" class="btn btn-cancel" onclick="cerrarModal()">Cancelar</button>
        <button type="button" class="btn btn-save" onclick="editarUsuario()">Guardar Cambios</button>
    </div>
</form>