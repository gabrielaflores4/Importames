@model IEnumerable<Importames.Models.UsuarioModel>
@{
    ViewData["Title"] = "Usuarios";
}

<div class="table-header">

    <div class="table-filters">
        <input type="text" placeholder="Buscar" class="input-search" />
    </div>

    <button class="btn btn-add" onclick="abrirModal()">
        <i class="bi bi-plus"></i> Registrar Usuario
    </button>

</div>

<div class="table-container">
    <table class="table">
        <thead>
            <tr>
                <th>CÓDIGO</th>
                <th>NOMBRE</th>
                <th>USERNAME</th>
                <th>ROL</th>
                <th>TELÉFONO</th>
                <th>ACCIONES</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var u in Model)
            {
                <tr onclick="abrirModalDetalles(@u.IdUsuario)" style="cursor: pointer;">
                    <td>@u.IdUsuario</td>
                    <td>@u.Nombre @u.Apellido</td>
                    <td>@u.Username</td>
                    <td>@u.Rol</td>
                    <td>@u.Telefono</td>

                    <td class="acciones" onclick="event.stopPropagation()">
                        <button class="btn btn-details" onclick="abrirModalDetalles(@u.IdUsuario)">
                            Detalles
                        </button>

                        <button class="btn btn-edit" onclick="abrirModalEditar(@u.IdUsuario)">
                            Editar
                        </button>

                        <button class="btn btn-delete" onclick="eliminarUsuario(@u.IdUsuario)">
                            Eliminar
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- MODAL PRINCIPAL -->
<div id="modal" class="modal">
    <div class="modal-content" id="modal-body">
    </div>
</div>

<!-- MODAL CONFIRMACIÓN -->
<div id="modal-confirm" class="modal-confirm">
    <div class="modal-confirm-content">
        <p id="confirm-mensaje" class="modal-confirm-mensaje"></p>
        <div class="modal-confirm-actions">
            <button class="btn btn-cancel" onclick="cancelarConfirm()">Cancelar</button>
            <button class="btn btn-save" id="confirm-aceptar">Aceptar</button>
        </div>
    </div>
</div>

<script src="~/js/usuarios.js"></script>