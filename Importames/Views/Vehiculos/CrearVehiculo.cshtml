@model Importames.Models.VehiculoModel
@{
    Layout = null;
}
<form id="formVehiculo" class="form-grid" autocomplete="off">
    <h2 class="form-title">Registrar Vehículo</h2>
    <div id="mensaje-modal" class="mensaje-form"></div>

    <div class="form-group">
        <label>MARCA</label>
        <input type="text" name="marca" required />
    </div>

    <div class="form-group">
        <label>MODELO</label>
        <input type="text" name="modelo" required />
    </div>

    <div class="form-group">
        <label>AÑO</label>
        <select name="anio" required>
            <option value=""></option>
            @for (int i = DateTime.Now.Year; i >= 1980; i--)
            {
                <option value="@i">@i</option>
            }
        </select>
    </div>

    <div class="form-group">
        <label>COLOR</label>
        <input type="text" name="color" required />
    </div>

    <div class="form-group full">
        <label>VIN</label>
        <input type="text" name="vin" maxlength="17" required />
    </div>

    <div class="form-group">
        <label>CLIENTE</label>
        <select name="IdCliente" required>
            <option value=""></option>
            @foreach (var c in ViewBag.Clientes)
            {
                <option value="@c.IdCliente">@($"{c.Nombre} {c.Apellido}")</option>
            }
        </select>
    </div>

    <div class="form-group">
        <label>COSTO</label>
        <input type="number" name="costo" step="0.01" min="0.01" required />
    </div>

    <div class="form-group full">
        <label>ESTADO INICIAL</label>
        @{
            var primerEstado = ((IEnumerable<Importames.Models.EstadosModel>)ViewBag.Estados).First();
        }
        <input type="hidden" name="IdEstado" value="@primerEstado.IdEstado" />
        <select disabled>
            <option>@primerEstado.NombreEstado</option>
        </select>
    </div>

    <div class="modal-actions full">
        <button type="button" class="btn btn-cancel" onclick="cerrarModal()">Cancelar</button>
        <button type="button" class="btn btn-save" onclick="guardarVehiculo()">Guardar</button>
    </div>
</form>