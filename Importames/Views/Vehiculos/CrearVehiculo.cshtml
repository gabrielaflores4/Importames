@model Importames.Models.VehiculoModel
@{
    Layout = null;
}

<form method="post" action="/Vehiculos/Create" class="form-grid">
    <h2 class="form-title">Registrar Vehículo</h2>

    <div class="form-group">
        <label>MARCA</label>
        <input type="text" name="marca" required />
    </div>

    <div class="form-group">
        <label>MODELO</label>
        <input type="text" name="modelo" required />
    </div>

    <div class="form-group">
        <label>AÑO</label>
        <select name="anio" required>
            <option value=""></option>
            @for (int i = DateTime.Now.Year; i >= 1980; i--)
            {
                <option value="@i">@i</option>
            }
        </select>
    </div>

    <div class="form-group">
        <label>COLOR</label>
        <input type="text" name="color" required />
    </div>

    <div class="form-group full">
        <label>VIN</label>
        <input type="text" name="vin" required />
    </div>

    <div class="form-group">
        <label>CLIENTE</label>
        <select name="IdCliente" required>
            <option value=""></option>
            @foreach (var c in ViewBag.Clientes)
            {
                <option value="@c.IdCliente">@($"{c.Nombre} {c.Apellido}")</option>
            }
        </select>
    </div>

    <div class="form-group">
        <label>COSTO</label>
        <input type="number" name="costo" step="0.01" required />
    </div>

    <div class="form-group full">
        <label>ESTADO INICIAL</label>
        <select name="IdEstado" required>
            <option value=""></option>
            @foreach (var e in ViewBag.Estados)
            {
                <option value="@e.IdEstado">@e.NombreEstado</option>
            }
        </select>
    </div>

    <div class="modal-actions full">
        <button type="button" class="btn btn-cancel" onclick="cerrarModal()">Cancelar</button>
        <button type="submit" class="btn btn-save">Guardar</button>
    </div>
</form>