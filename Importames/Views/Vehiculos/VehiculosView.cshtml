@model IEnumerable<Importames.Models.VehiculoModel>
@{
    ViewData["Title"] = "Vehículos";
}

<div class="table-header">

    <div class="table-filters">
        <input type="text" placeholder="Buscar" class="input-search" />

        <div class="filters">
            <form method="get">
                <select class="select" name="estadoId" onchange="this.form.submit()">
                    <option value="">Todos</option>

                    @foreach (var e in ViewBag.Estados)
                    {
                        <option value="@e.IdEstado"
                                selected="@(Context.Request.Query["estadoId"] == e.IdEstado.ToString())">
                            @e.NombreEstado
                        </option>
                    }
                </select>
            </form>
        </div>
    </div>

    <div style="display:flex; gap:10px;">

        <button class="btn btn-add" onclick="abrirModal()">
            <i class="bi bi-plus"></i> Registrar Vehículo
        </button>

        <a asp-action="GenerarReporte"
           asp-route-estadoId="@Context.Request.Query["estadoId"]"
           class="btn btn-edit">
            <i class="bi bi-file-earmark-pdf"></i>
            Generar Reporte
        </a>

    </div>

</div>

<div class="table-container">
    <table class="table">
        <thead>
            <tr>
                <th>VIN / CÓDIGO</th>
                <th>VEHÍCULO</th>
                <th>CLIENTE</th>
                <th>ESTADO</th>
                <th>AÑO</th>
                <th>COSTO</th>
                <th>ACCIONES</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var v in Model)
            {
                <tr>
                    <td>@v.Vin</td>
                    <td>@v.Marca @v.Modelo</td>
                    <td>@($"{v.Cliente.Nombre} {v.Cliente.Apellido}")</td>
                    <td>
                        @{
                            string clase = "estado-badge";
                            switch (v.Estado.NombreEstado)
                            {
                                case "En tránsito":
                                    clase += " badge-cyan";
                                    break;
                                case "En aduana":
                                    clase += " badge-yellow";
                                    break;
                                case "En preparación":
                                    clase += " badge-purple";
                                    break;
                                case "Trámites pendientes":
                                    clase += " badge-red";
                                    break;
                                case "Listo para entrega":
                                    clase += " badge-blue";
                                    break;
                                case "Entregado":
                                    clase += " badge-green";
                                    break;
                                default:
                                    clase += " badge-blue";
                                    break;
                            }
                        }
                        <span class="@clase">@v.Estado.NombreEstado</span>
                    </td>
                    <td>@v.Anio</td>
                    <td>$@v.Costo</td>
                    <td class="acciones">
                        <button class="btn btn-details" onclick="abrirModalDetalles(@v.IdVehiculo)">
                            Detalles
                        </button>

                        <button class="btn btn-edit" onclick="abrirModalEditar(@v.IdVehiculo)">
                            Editar
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>

<div id="modal" class="modal">
    <div class="modal-content" id="modal-body">
    </div>
</div>
<div id="modal-confirm" class="modal-confirm">
    <div class="modal-confirm-content">
        <p id="confirm-mensaje" class="modal-confirm-mensaje"></p>
        <div class="modal-confirm-actions">
            <button class="btn btn-cancel" onclick="cancelarConfirm()">Cancelar</button>
            <button class="btn btn-save" id="confirm-aceptar">Aceptar</button>
        </div>
    </div>
</div>
@section Scripts {
    <script src="~/js/vehiculos.js"></script>
}