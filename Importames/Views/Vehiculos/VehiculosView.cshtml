@{
    ViewData["Title"] = "Vehículos";
}

<div class="table-header">

    <div class="table-filters">
        <input type="text" placeholder="Buscar" class="input-search" />

        <div class="filters">
            <select class="select">
                <option>Categoría</option>
            </select>

            <select class="select">
                <option>Estado</option>
            </select>
        </div>
    </div>

    <button class="btn-primary">
        <i class="bi bi-plus"></i> Registrar Vehículo
    </button>

</div>

<div class="table-container">
    <table class="table">
        <thead>
            <tr>
                <th>VIN / CÓDIGO</th>
                <th>VEHÍCULO</th>
                <th>CLIENTE</th>
                <th>ESTADO</th>
                <th>AÑO</th>
                <th>COSTO</th>
                <th>ACCIONES</th>
            </tr>
        </thead>

        <tbody>
            <tr>
                
            </tr>
        </tbody>
    </table>

</div>